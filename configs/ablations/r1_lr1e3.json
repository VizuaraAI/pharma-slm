{
  "model": {
    "vocab_size": 32000,
    "dim": 1024,
    "n_layers": 24,
    "n_heads": 16,
    "max_seq_len": 2048
  },
  "train": {
    "group": "sweep_r1",
    "data_dir": "/vol/data",
    "tokenizer_path": "/vol/tokenizer/tokenizer.json",
    "mix": {
      "fineweb_edu": 0.65,
      "pubmed": 0.35
    },
    "seq_len": 1024,
    "batch_size": 24,
    "grad_accum": 6,
    "lr": 0.001,
    "min_lr": 6e-05,
    "warmup_steps": 150,
    "max_steps": 6000,
    "target_tokens": 350000000,
    "eval_interval": 250,
    "eval_steps": 40,
    "log_interval": 25,
    "save_interval": 2000,
    "abandon_enable": true,
    "abandon_min_steps": 800,
    "abandon_patience": 3,
    "abandon_loss_ceiling": 8.0,
    "dtype": "bfloat16",
    "compile": true,
    "name": "r1_lr1e3"
  }
}